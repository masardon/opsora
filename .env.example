# =============================================================================
# Opsora Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# GCP Configuration
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
BIGQUERY_DATASET=opsora
GCS_BUCKET=opsora-data

# -----------------------------------------------------------------------------
# PubSub Configuration
# -----------------------------------------------------------------------------
PUBSUB_TOPIC_SALES=events-sales
PUBSUB_TOPIC_OPERATIONS=events-operations
PUBSUB_TOPIC_CUSTOMERS=events-customers
PUBSUB_TOPIC_REVENUE=events-revenue
PUBSUB_TOPIC_ALL=events-all

PUBSUB_SUBSCRIPTION_ANALYTICS=analytics-sub

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# Options: anthropic, openai, glm, vertexai, local
LLM_PROVIDER=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# OpenAI (if using)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# GLM / Zhipu AI (if using)
GLM_API_KEY=your-glm-api-key
GLM_MODEL=glm-4-flash
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Google Vertex AI (if using)
VERTEXAI_PROJECT=your-project-id
VERTEXAI_LOCATION=us-central1
VERTEXAI_MODEL=gemini-pro

# Local LLM (if using Ollama)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama2

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
AGENT_MAX_ITERATIONS=5
AGENT_TIMEOUT=30
AGENT_DEBUG=false

# Confidence thresholds for recommendations
RECOMMENDATION_CONFIDENCE_THRESHOLD=0.7
ACTION_CONFIDENCE_THRESHOLD=0.85

# Scoring weights
SCORE_WEIGHT_CONFIDENCE=0.3
SCORE_WEIGHT_IMPACT=0.3
SCORE_WEIGHT_URGENCY=0.25
SCORE_WEIGHT_EFFORT=0.15

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=4
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# -----------------------------------------------------------------------------
# Dashboard Configuration
# -----------------------------------------------------------------------------
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501
DASHBOARD_THEME=light

# -----------------------------------------------------------------------------
# Redis Configuration (for caching and pub/sub)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Celery Configuration (for async tasks)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/opsora.log

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
ENABLE_METRICS=true
ENABLE_TRACING=false
METRICS_PORT=9090

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_REALTIME_ANALYTICS=true
FEATURE_BATCH_ANALYTICS=true
FEATURE_AUTO_ACTIONS=false
FEATURE_WEBHOOK_NOTIFICATIONS=true
FEATURE_SLACK_INTEGRATION=false
